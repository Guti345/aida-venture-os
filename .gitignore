# CRÍTICO: credenciales — NUNCA subir a GitHub
.env
.env.local
.env.production

# El .env.example SÍ se sube — es solo un template sin valores reales
# .env.example  ← NO ignorar este archivo

# ═══ Python ═══
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# ═══ Entorno virtual ═══
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
__pypackages__/

